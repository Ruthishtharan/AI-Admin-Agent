# ── LLM Backend ─────────────────────────────────────────────────────────────
# "ollama"     → free local model, no API key needed (default)
# "anthropic"  → Claude claude-sonnet-4-6, needs credits
LLM_BACKEND=ollama

# ── Ollama (free, runs locally) ──────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# ── Anthropic (optional) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Flask ────────────────────────────────────────────────────────────────────
BASE_URL=http://127.0.0.1:5000
FLASK_PORT=5000
HEADLESS=false

# ── Slack Bot (for slack_bot.py) ─────────────────────────────────────────────
# See setup instructions at the top of slack_bot.py
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# ── SaaS Agent (for saas_agent.py) ───────────────────────────────────────────
# Choose target: hubspot | notion | google | custom
SAAS_TARGET=hubspot
SAAS_EMAIL=your@email.com
SAAS_PASSWORD=yourpassword
# Only needed when SAAS_TARGET=custom:
SAAS_URL=
SAAS_NAME=My Admin Panel
SAAS_EXTRA=
